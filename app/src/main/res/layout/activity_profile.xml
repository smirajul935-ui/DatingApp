<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0A0A1A"
    android:orientation="vertical"
    android:gravity="center_horizontal"
    android:padding="24dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:text="Setup Profile 👤"
        android:textColor="#FFFFFF"
        android:textSize="26sp"
        android:textStyle="bold"
        android:layout_marginBottom="20dp"/>

    <!-- MAIN AVATAR (Jo select hoga wo yaha dikhega) -->
    <ImageView
        android:id="@+id/ivAvatar"
        android:layout_width="120dp"
        android:layout_height="120dp"
        android:background="@drawable/bg_speaker_glow"
        android:padding="8dp"
        android:src="@android:drawable/sym_def_app_icon" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Choose your Avatar below 👇"
        android:textColor="#AAAAAA"
        android:textSize="14sp"
        android:layout_marginTop="15dp"
        android:layout_marginBottom="10dp"/>

    <!-- 🖼️ AVATAR SELECTION LIST (Horizontal Scroll) -->
    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:scrollbars="none"
        android:layout_marginBottom="25dp">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center">

            <ImageView android:id="@+id/av1" android:layout_width="60dp" android:layout_height="60dp" android:layout_marginRight="15dp" android:background="@drawable/bg_round_dark" android:padding="5dp"/>
            <ImageView android:id="@+id/av2" android:layout_width="60dp" android:layout_height="60dp" android:layout_marginRight="15dp" android:background="@drawable/bg_round_dark" android:padding="5dp"/>
            <ImageView android:id="@+id/av3" android:layout_width="60dp" android:layout_height="60dp" android:layout_marginRight="15dp" android:background="@drawable/bg_round_dark" android:padding="5dp"/>
            <ImageView android:id="@+id/av4" android:layout_width="60dp" android:layout_height="60dp" android:layout_marginRight="15dp" android:background="@drawable/bg_round_dark" android:padding="5dp"/>
            <ImageView android:id="@+id/av5" android:layout_width="60dp" android:layout_height="60dp" android:layout_marginRight="15dp" android:background="@drawable/bg_round_dark" android:padding="5dp"/>
            <ImageView android:id="@+id/av6" android:layout_width="60dp" android:layout_height="60dp" android:background="@drawable/bg_round_dark" android:padding="5dp"/>
        </LinearLayout>
    </HorizontalScrollView>

    <!-- Name Box -->
    <EditText
        android:id="@+id/etUserName"
        android:layout_width="match_parent"
        android:layout_height="55dp"
        android:hint="Enter Your Name"
        android:textColorHint="#888888"
        android:textColor="#FFFFFF"
        android:background="@drawable/bg_round_dark"
        android:paddingHorizontal="15dp"
        android:inputType="textPersonName"
        android:layout_marginBottom="20dp"/>

    <!-- Gender Selection -->
    <RadioGroup
        android:id="@+id/rgGender"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="30dp">
        
        <RadioButton
            android:id="@+id/rbMale"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Male 👨"
            android:textColor="#FFFFFF"
            android:buttonTint="#2196F3"
            android:checked="true"
            android:layout_marginRight="30dp"/>

        <RadioButton
            android:id="@+id/rbFemale"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Female 👩"
            android:buttonTint="#E91E63"
            android:textColor="#FFFFFF"/>
    </RadioGroup>

    <!-- Save Button -->
    <Button
        android:id="@+id/btnSaveProfile"
        android:layout_width="match_parent"
        android:layout_height="55dp"
        android:text="SAVE PROFILE"
        android:background="@drawable/bg_gradient_button"
        android:textColor="#FFFFFF"
        android:textSize="18sp"
        android:textStyle="bold"/>

</LinearLayout>
