<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0A0A1A"
    android:padding="20dp">

    <!-- 🌟 TOP BAR -->
    <RelativeLayout
        android:id="@+id/topBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="25dp">

        <ImageView
            android:id="@+id/btnMessages"
            android:layout_width="35dp"
            android:layout_height="35dp"
            android:layout_alignParentLeft="true"
            android:layout_centerVertical="true"
            android:src="@android:drawable/ic_dialog_email"
            android:tint="#FFFFFF"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:text="LiveChat •"
            android:textColor="#FFFFFF"
            android:textSize="26sp"
            android:textStyle="bold"/>
        <!-- Create Room Button (Plus Icon) -->
        <ImageView
            android:id="@+id/btnCreateRoom"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_toLeftOf="@id/btnProfile"
            android:layout_centerVertical="true"
            android:layout_marginRight="15dp"
            android:background="@drawable/bg_button"
            android:src="@android:drawable/ic_input_add"
            android:padding="8dp"
            android:tint="#FFFFFF"/>

        <ImageView
            android:id="@+id/btnProfile"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_alignParentRight="true"
            android:layout_centerVertical="true"
            android:background="@drawable/bg_button"
            android:src="@android:drawable/ic_menu_myplaces"
            android:tint="#FFFFFF"/>
    </RelativeLayout>

    <!-- 📜 SCROLLABLE CONTENT -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/topBar"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Chatrooms"
                android:textColor="#FFFFFF"
                android:textSize="20sp"
                android:textStyle="bold"
                android:layout_marginBottom="15dp"/>

            <!-- 💖 CARD 1: Love Talk -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="100dp"
                android:background="@drawable/bg_card"
                android:padding="20dp"
                android:layout_marginBottom="15dp">
                
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Love Talk 💕"
                    android:textColor="#FFFFFF"
                    android:textSize="22sp"
                    android:textStyle="bold"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentBottom="true"
                    android:text="👥 25 online"
                    android:textColor="#AAAAAA"/>

                <!-- Join Button (Love Talk) -->
                <Button
                    android:id="@+id/btnJoinLoveTalk"
                    android:layout_width="90dp"
                    android:layout_height="45dp"
                    android:layout_alignParentRight="true"
                    android:layout_centerVertical="true"
                    android:background="@drawable/bg_button"
                    android:text="Join"
                    android:textColor="#FFFFFF"
                    android:textAllCaps="false"
                    android:onClick="joinRoom"/>
            </RelativeLayout>

            <!-- 🎵 CARD 2: Vibe and Chill -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="100dp"
                android:background="@drawable/bg_card"
                android:padding="20dp"
                android:layout_marginBottom="25dp">
                
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Vibe and Chill 🎵"
                    android:textColor="#FFFFFF"
                    android:textSize="22sp"
                    android:textStyle="bold"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentBottom="true"
                    android:text="👥 13 online"
                    android:textColor="#AAAAAA"/>

                <!-- Join Button (Vibe) -->
                <Button
                    android:id="@+id/btnJoinVibe"
                    android:layout_width="90dp"
                    android:layout_height="45dp"
                    android:layout_alignParentRight="true"
                    android:layout_centerVertical="true"
                    android:background="@drawable/bg_button"
                    android:text="Join"
                    android:textColor="#FFFFFF"
                    android:textAllCaps="false"
                    android:onClick="joinRoom"/>
            </RelativeLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Video Chatrooms"
                android:textColor="#FFFFFF"
                android:textSize="20sp"
                android:textStyle="bold"
                android:layout_marginBottom="15dp"/>

            <!-- HORIZONTAL SCROLL -->
            <HorizontalScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:scrollbars="none">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <!-- 🔥 VIDEO CARD 1 -->
                    <RelativeLayout
                        android:layout_width="220dp"
                        android:layout_height="130dp"
                        android:background="@drawable/bg_card"
                        android:padding="15dp"
                        android:layout_marginRight="15dp">
                        
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Flirting Zone 🔥"
                            android:textColor="#FFFFFF"
                            android:textSize="18sp"
                            android:textStyle="bold"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_alignParentBottom="true"
                            android:text="20 online"
                            android:textColor="#AAAAAA"/>

                        <!-- Join Button (Flirting) -->
                        <Button
                            android:id="@+id/btnJoinFlirt"
                            android:layout_width="80dp"
                            android:layout_height="40dp"
                            android:layout_alignParentRight="true"
                            android:layout_alignParentBottom="true"
                            android:background="@drawable/bg_button"
                            android:text="Join"
                            android:textColor="#FFFFFF"
                            android:textAllCaps="false"
                            android:onClick="joinRoom"/>
                    </RelativeLayout>

                    <!-- 👋 VIDEO CARD 2 -->
                    <RelativeLayout
                        android:layout_width="220dp"
                        android:layout_height="130dp"
                        android:background="@drawable/bg_card"
                        android:padding="15dp"
                        android:layout_marginRight="15dp">
                        
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Let's Connect 👋"
                            android:textColor="#FFFFFF"
                            android:textSize="18sp"
                            android:textStyle="bold"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_alignParentBottom="true"
                            android:text="26 online"
                            android:textColor="#AAAAAA"/>

                        <!-- Join Button (Connect) -->
                        <Button
                            android:id="@+id/btnJoinConnect"
                            android:layout_width="80dp"
                            android:layout_height="40dp"
                            android:layout_alignParentRight="true"
                            android:layout_alignParentBottom="true"
                            android:background="@drawable/bg_button"
                            android:text="Join"
                            android:textColor="#FFFFFF"
                            android:textAllCaps="false"
                            android:onClick="joinRoom"/>
                    </RelativeLayout>

                </LinearLayout>
            </HorizontalScrollView>
        </LinearLayout>
    </ScrollView>
</RelativeLayout>
