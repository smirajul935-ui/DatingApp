<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_card"
    android:padding="20dp"
    android:layout_marginBottom="15dp"
    android:layout_marginHorizontal="20dp">

    <!-- Room Name (Jaise "Love Talk 💕") -->
    <TextView
        android:id="@+id/tvRoomTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Room Name"
        android:textColor="#FFFFFF"
        android:textSize="22sp"
        android:textStyle="bold"/>

    <!-- Online Count (Jaise "👥 25 online") -->
    <TextView
        android:id="@+id/tvOnlineCount"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_below="@id/tvRoomTitle"
        android:layout_marginTop="5dp"
        android:text="👥 1 online"
        android:textColor="#AAAAAA"/>

    <!-- Room Type Label (Voice ya Video) -->
    <TextView
        android:id="@+id/tvRoomType"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_below="@id/tvOnlineCount"
        android:layout_marginTop="5dp"
        android:text="Voice Chat"
        android:textColor="#E91E63"
        android:textSize="12sp"
        android:textStyle="bold"/>

    <!-- Join Button -->
    <Button
        android:id="@+id/btnJoinDynamic"
        android:layout_width="90dp"
        android:layout_height="45dp"
        android:layout_alignParentRight="true"
        android:layout_centerVertical="true"
        android:background="@drawable/bg_button"
        android:text="Join"
        android:textColor="#FFFFFF"
        android:textAllCaps="false"/>
</RelativeLayout>
