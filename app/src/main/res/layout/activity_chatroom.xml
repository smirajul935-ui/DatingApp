<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#121215"> <!-- Dark Blue/Black Theme -->

    <!-- 🌟 TOP BAR (Host Info & Mini Seats) -->
    <RelativeLayout
        android:id="@+id/topBar"
        android:layout_width="match_parent"
        android:layout_height="80dp"
        android:background="#1E1E28"
        android:paddingHorizontal="10dp"
        android:paddingVertical="5dp"
        android:elevation="4dp">

        <!-- Host Profile & Room Info -->
        <LinearLayout
            android:id="@+id/hostInfo"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerVertical="true"
            android:orientation="horizontal">

            <ImageView
                android:id="@+id/ivHostAvatar"
                android:layout_width="50dp"
                android:layout_height="50dp"
                android:src="@android:drawable/ic_menu_myplaces"
                android:background="@drawable/bg_neon_circle"
                android:padding="5dp"
                android:tint="#FFFFFF"/>

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginLeft="10dp"
                android:layout_gravity="center_vertical">

                <TextView
                    android:id="@+id/tvRoomName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="👑 No Option..."
                    android:textColor="#FFD700"
                    android:textSize="16sp"
                    android:textStyle="bold"/>

                <!-- Level Badge -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_button"
                    android:paddingHorizontal="6dp"
                    android:paddingVertical="2dp"
                    android:text="Lv 12"
                    android:textColor="#FFFFFF"
                    android:textSize="10sp"
                    android:layout_marginTop="2dp"/>
            </LinearLayout>
        </LinearLayout>

        <!-- Mini Seats (Top Right) -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentRight="true"
            android:layout_centerVertical="true"
            android:orientation="horizontal">

            <!-- Requests Circle -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:layout_marginRight="10dp">
                <TextView
                    android:layout_width="35dp"
                    android:layout_height="35dp"
                    android:background="@drawable/bg_round_dark"
                    android:gravity="center"
                    android:text="0"
                    android:textColor="#FFFFFF"
                    android:textSize="16sp"
                    android:textStyle="bold"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Request"
                    android:textColor="#AAAAAA"
                    android:textSize="10sp"/>
            </LinearLayout>

            <!-- Locked Seats (Dash line circles) -->
            <ImageView
                android:layout_width="35dp"
                android:layout_height="35dp"
                android:background="@drawable/bg_round_dark"
                android:src="@android:drawable/ic_secure"
                android:tint="#888888"
                android:padding="8dp"
                android:layout_marginRight="5dp"/>
            
            <ImageView
                android:layout_width="35dp"
                android:layout_height="35dp"
                android:background="@drawable/bg_round_dark"
                android:src="@android:drawable/ic_secure"
                android:tint="#888888"
                android:padding="8dp"
                android:layout_marginRight="5dp"/>
                
            <ImageView
                android:layout_width="35dp"
                android:layout_height="35dp"
                android:background="@drawable/bg_round_dark"
                android:src="@android:drawable/ic_secure"
                android:tint="#888888"
                android:padding="8dp"/>
        </LinearLayout>
    </RelativeLayout>

    <!-- 🎙️ MIC INDICATOR BAR -->
    <LinearLayout
        android:id="@+id/micIndicator"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@id/topBar"
        android:background="#2A2A35"
        android:padding="8dp"
        android:orientation="horizontal"
        android:gravity="center_vertical">
        
        <ImageView
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:src="@android:drawable/ic_btn_speak_now"
            android:tint="#FFC107"/>
            
        <TextView
            android:id="@+id/tvMicStatus"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginLeft="10dp"
            android:text="Your mic is off. Tap below to speak!"
            android:textColor="#FFFFFF"
            android:textSize="14sp"/>
            
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="X"
            android:textColor="#888888"
            android:textStyle="bold"
            android:paddingHorizontal="10dp"/>
    </LinearLayout>

    <!-- 💬 LIVE CHAT COMMENTS SECTION -->
    <ScrollView
        android:id="@+id/chatScroll"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/micIndicator"
        android:layout_above="@id/bottomControls"
        android:padding="10dp"
        android:scrollbars="none">

        <!-- Here messages will appear in modern style via Java -->
        <LinearLayout
            android:id="@+id/layoutMessages"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">
        </LinearLayout>
    </ScrollView>

    <!-- 🎛️ BOTTOM CONTROLS (Input + Gift/Mic icons) -->
    <RelativeLayout
        android:id="@+id/bottomControls"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:background="#1E1E28"
        android:padding="10dp">

        <!-- Mic Button (Left) -->
        <ImageView
            android:id="@+id/btnMic"
            android:layout_width="45dp"
            android:layout_height="45dp"
            android:layout_alignParentLeft="true"
            android:layout_centerVertical="true"
            android:background="@drawable/bg_round_dark"
            android:src="@android:drawable/ic_btn_speak_now"
            android:tint="#888888"
            android:padding="10dp"/>

        <!-- Message Input Box -->
        <EditText
            android:id="@+id/etMessage"
            android:layout_width="match_parent"
            android:layout_height="45dp"
            android:layout_toRightOf="@id/btnMic"
            android:layout_toLeftOf="@id/rightIcons"
            android:layout_centerVertical="true"
            android:layout_marginHorizontal="10dp"
            android:background="@drawable/bg_round_dark"
            android:hint="Say something..."
            android:textColorHint="#888888"
            android:textColor="#FFFFFF"
            android:paddingHorizontal="15dp"
            android:textSize="14sp"/>

        <!-- Right Icons (Gift, Clipboard, Send) -->
        <LinearLayout
            android:id="@+id/rightIcons"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentRight="true"
            android:layout_centerVertical="true"
            android:orientation="horizontal">
            
            <ImageView
                android:layout_width="35dp"
                android:layout_height="35dp"
                android:src="@android:drawable/ic_menu_agenda"
                android:tint="#FFC107"
                android:layout_marginRight="10dp"/>

            <!-- Send Button -->
            <ImageView
                android:id="@+id/btnSend"
                android:layout_width="45dp"
                android:layout_height="45dp"
                android:background="@drawable/bg_button"
                android:src="@android:drawable/ic_menu_send"
                android:tint="#FFFFFF"
                android:padding="10dp"/>
        </LinearLayout>
    </RelativeLayout>

</RelativeLayout>
