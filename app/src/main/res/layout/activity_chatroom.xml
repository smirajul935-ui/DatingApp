<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0A0A1A">

    <!-- 🌟 TOP BAR (Room Name & Listeners) -->
    <RelativeLayout
        android:id="@+id/topBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="15dp">

        <TextView
            android:id="@+id/tvRoomName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Love Talk 💕"
            android:textColor="#FFFFFF"
            android:textSize="22sp"
            android:textStyle="bold"/>

        <TextView
            android:id="@+id/tvListeners"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentRight="true"
            android:layout_centerVertical="true"
            android:background="@drawable/bg_round_dark"
            android:paddingHorizontal="12dp"
            android:paddingVertical="5dp"
            android:text="👁 20 Listening"
            android:textColor="#AAAAAA"/>
    </RelativeLayout>

    <!-- 🪑 8 SEATS GRID (2 Rows of 4) -->
    <LinearLayout
        android:id="@+id/seatsLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@id/topBar"
        android:orientation="vertical"
        android:padding="10dp">

        <!-- ROW 1 (4 Seats) -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:weightSum="4"
            android:layout_marginBottom="15dp">

            <!-- SEAT 1 (Host) -->
            <LinearLayout android:id="@+id/seat1" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:gravity="center" android:orientation="vertical">
                <ImageView android:layout_width="60dp" android:layout_height="60dp" android:background="@drawable/bg_neon_circle" android:src="@android:drawable/ic_menu_myplaces" android:tint="#FFFFFF" android:padding="10dp"/>
                <TextView android:id="@+id/tvSeat1" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Host" android:textColor="#E91E63" android:textStyle="bold" android:layout_marginTop="5dp"/>
            </LinearLayout>

            <!-- SEAT 2 -->
            <LinearLayout android:id="@+id/seat2" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:gravity="center" android:orientation="vertical">
                <ImageView android:layout_width="60dp" android:layout_height="60dp" android:background="@drawable/bg_round_dark" android:src="@android:drawable/ic_menu_add" android:tint="#AAAAAA" android:padding="15dp"/>
                <TextView android:id="@+id/tvSeat2" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Empty" android:textColor="#AAAAAA" android:layout_marginTop="5dp"/>
            </LinearLayout>

            <!-- SEAT 3 -->
            <LinearLayout android:id="@+id/seat3" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:gravity="center" android:orientation="vertical">
                <ImageView android:layout_width="60dp" android:layout_height="60dp" android:background="@drawable/bg_round_dark" android:src="@android:drawable/ic_menu_add" android:tint="#AAAAAA" android:padding="15dp"/>
                <TextView android:id="@+id/tvSeat3" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Empty" android:textColor="#AAAAAA" android:layout_marginTop="5dp"/>
            </LinearLayout>

            <!-- SEAT 4 -->
            <LinearLayout android:id="@+id/seat4" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:gravity="center" android:orientation="vertical">
                <ImageView android:layout_width="60dp" android:layout_height="60dp" android:background="@drawable/bg_round_dark" android:src="@android:drawable/ic_menu_add" android:tint="#AAAAAA" android:padding="15dp"/>
                <TextView android:id="@+id/tvSeat4" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Empty" android:textColor="#AAAAAA" android:layout_marginTop="5dp"/>
            </LinearLayout>
        </LinearLayout>

        <!-- ROW 2 (4 Seats) -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:weightSum="4">

            <!-- SEAT 5 TO 8 -->
            <LinearLayout android:id="@+id/seat5" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:gravity="center" android:orientation="vertical">
                <ImageView android:layout_width="60dp" android:layout_height="60dp" android:background="@drawable/bg_round_dark" android:src="@android:drawable/ic_menu_add" android:tint="#AAAAAA" android:padding="15dp"/>
                <TextView android:id="@+id/tvSeat5" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Empty" android:textColor="#AAAAAA" android:layout_marginTop="5dp"/>
            </LinearLayout>
            <LinearLayout android:id="@+id/seat6" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:gravity="center" android:orientation="vertical">
                <ImageView android:layout_width="60dp" android:layout_height="60dp" android:background="@drawable/bg_round_dark" android:src="@android:drawable/ic_menu_add" android:tint="#AAAAAA" android:padding="15dp"/>
                <TextView android:id="@+id/tvSeat6" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Empty" android:textColor="#AAAAAA" android:layout_marginTop="5dp"/>
            </LinearLayout>
            <LinearLayout android:id="@+id/seat7" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:gravity="center" android:orientation="vertical">
                <ImageView android:layout_width="60dp" android:layout_height="60dp" android:background="@drawable/bg_round_dark" android:src="@android:drawable/ic_menu_add" android:tint="#AAAAAA" android:padding="15dp"/>
                <TextView android:id="@+id/tvSeat7" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Empty" android:textColor="#AAAAAA" android:layout_marginTop="5dp"/>
            </LinearLayout>
            <LinearLayout android:id="@+id/seat8" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:gravity="center" android:orientation="vertical">
                <ImageView android:layout_width="60dp" android:layout_height="60dp" android:background="@drawable/bg_round_dark" android:src="@android:drawable/ic_menu_add" android:tint="#AAAAAA" android:padding="15dp"/>
                <TextView android:id="@+id/tvSeat8" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Empty" android:textColor="#AAAAAA" android:layout_marginTop="5dp"/>
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>

    <!-- 💬 LIVE CHAT COMMENTS SECTION -->
    <ScrollView
        android:id="@+id/chatScroll"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/seatsLayout"
        android:layout_above="@id/bottomControls"
        android:padding="15dp"
        android:scrollbars="none">

        <LinearLayout
            android:id="@+id/layoutMessages"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">
        </LinearLayout>
    </ScrollView>

    <!-- 🎛️ BOTTOM CONTROLS -->
    <LinearLayout
        android:id="@+id/bottomControls"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:orientation="vertical"
        android:background="#0A0A1A"
        android:padding="15dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="15dp">
            
            <EditText
                android:id="@+id/etMessage"
                android:layout_width="0dp"
                android:layout_height="45dp"
                android:layout_weight="1"
                android:background="@drawable/bg_round_dark"
                android:hint="+ Send a message..."
                android:textColorHint="#888888"
                android:textColor="#FFFFFF"
                android:paddingHorizontal="15dp"/>
                
            <Button
                android:id="@+id/btnSend"
                android:layout_width="50dp"
                android:layout_height="45dp"
                android:layout_marginLeft="10dp"
                android:background="@drawable/bg_round_dark"
                android:text="➤"
                android:textColor="#2196F3"/>
        </LinearLayout>

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <ImageView
                android:id="@+id/btnMic"
                android:layout_width="50dp"
                android:layout_height="50dp"
                android:layout_alignParentLeft="true"
                android:background="@drawable/bg_round_dark"
                android:src="@android:drawable/ic_btn_speak_now"
                android:tint="#8A2BE2"
                android:padding="10dp"/>

            <Button
                android:id="@+id/btnLeave"
                android:layout_width="160dp"
                android:layout_height="50dp"
                android:layout_centerInParent="true"
                android:background="@drawable/bg_leave_btn"
                android:text="Leave"
                android:textColor="#FFFFFF"
                android:textSize="18sp"
                android:textAllCaps="false"/>

            <ImageView
                android:id="@+id/btnVideo"
                android:layout_width="50dp"
                android:layout_height="50dp"
                android:layout_alignParentRight="true"
                android:background="@drawable/bg_round_dark"
                android:src="@android:drawable/ic_menu_camera"
                android:tint="#2196F3"
                android:padding="10dp"/>
        </RelativeLayout>
    </LinearLayout>

</RelativeLayout>
