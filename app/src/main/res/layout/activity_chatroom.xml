<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#121215">

    <!-- 🌟 TOP BAR (Host Info) -->
    <RelativeLayout
        android:id="@+id/topBar"
        android:layout_width="match_parent"
        android:layout_height="80dp"
        android:background="#1E1E28"
        android:paddingHorizontal="15dp"
        android:paddingVertical="5dp"
        android:elevation="4dp">

        <!-- Host Profile & Room Info -->
        <LinearLayout
            android:id="@+id/hostInfo"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerVertical="true"
            android:orientation="horizontal">

            <ImageView
                android:id="@+id/ivHostAvatar"
                android:layout_width="50dp"
                android:layout_height="50dp"
                android:src="@android:drawable/ic_menu_myplaces"
                android:background="@drawable/bg_neon_circle"
                android:padding="5dp"
                android:tint="#FFFFFF"/>

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginLeft="10dp"
                android:layout_gravity="center_vertical">

                <TextView
                    android:id="@+id/tvRoomName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="👑 Room Name"
                    android:textColor="#FFD700"
                    android:textSize="16sp"
                    android:textStyle="bold"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_button"
                    android:paddingHorizontal="6dp"
                    android:paddingVertical="2dp"
                    android:text="Lv 1"
                    android:textColor="#FFFFFF"
                    android:textSize="10sp"
                    android:layout_marginTop="2dp"/>
            </LinearLayout>
        </LinearLayout>

        <!-- Right Side: Close Button (Will open Minimize/Exit dialog) -->
        <ImageView
            android:id="@+id/btnClose"
            android:layout_width="35dp"
            android:layout_height="35dp"
            android:layout_alignParentRight="true"
            android:layout_centerVertical="true"
            android:src="@android:drawable/ic_menu_close_clear_cancel"
            android:tint="#FFFFFF"/>
    </RelativeLayout>

    <!-- 🪑 8 SEATS GRID (2 Rows of 4, Video Jaisa Modern Look) -->
    <LinearLayout
        android:id="@+id/seatsLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@id/topBar"
        android:orientation="vertical"
        android:padding="15dp"
        android:layout_marginTop="10dp">

        <!-- ROW 1 (4 Seats) -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:weightSum="4"
            android:layout_marginBottom="20dp">

            <LinearLayout android:id="@+id/seat1" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:gravity="center" android:orientation="vertical">
                <ImageView android:layout_width="60dp" android:layout_height="60dp" android:background="@drawable/bg_round_dark" android:src="@android:drawable/ic_secure" android:tint="#888888" android:padding="15dp"/>
                <TextView android:id="@+id/tvSeat1" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Empty" android:textColor="#888888" android:textSize="12sp" android:layout_marginTop="5dp"/>
            </LinearLayout>

            <LinearLayout android:id="@+id/seat2" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:gravity="center" android:orientation="vertical">
                <ImageView android:layout_width="60dp" android:layout_height="60dp" android:background="@drawable/bg_round_dark" android:src="@android:drawable/ic_secure" android:tint="#888888" android:padding="15dp"/>
                <TextView android:id="@+id/tvSeat2" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Empty" android:textColor="#888888" android:textSize="12sp" android:layout_marginTop="5dp"/>
            </LinearLayout>

            <LinearLayout android:id="@+id/seat3" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:gravity="center" android:orientation="vertical">
                <ImageView android:layout_width="60dp" android:layout_height="60dp" android:background="@drawable/bg_round_dark" android:src="@android:drawable/ic_secure" android:tint="#888888" android:padding="15dp"/>
                <TextView android:id="@+id/tvSeat3" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Empty" android:textColor="#888888" android:textSize="12sp" android:layout_marginTop="5dp"/>
            </LinearLayout>

            <LinearLayout android:id="@+id/seat4" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:gravity="center" android:orientation="vertical">
                <ImageView android:layout_width="60dp" android:layout_height="60dp" android:background="@drawable/bg_round_dark" android:src="@android:drawable/ic_secure" android:tint="#888888" android:padding="15dp"/>
                <TextView android:id="@+id/tvSeat4" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Empty" android:textColor="#888888" android:textSize="12sp" android:layout_marginTop="5dp"/>
            </LinearLayout>
        </LinearLayout>

        <!-- ROW 2 (4 Seats) -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:weightSum="4">

            <LinearLayout android:id="@+id/seat5" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:gravity="center" android:orientation="vertical">
                <ImageView android:layout_width="60dp" android:layout_height="60dp" android:background="@drawable/bg_round_dark" android:src="@android:drawable/ic_secure" android:tint="#888888" android:padding="15dp"/>
                <TextView android:id="@+id/tvSeat5" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Empty" android:textColor="#888888" android:textSize="12sp" android:layout_marginTop="5dp"/>
            </LinearLayout>

            <LinearLayout android:id="@+id/seat6" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:gravity="center" android:orientation="vertical">
                <ImageView android:layout_width="60dp" android:layout_height="60dp" android:background="@drawable/bg_round_dark" android:src="@android:drawable/ic_secure" android:tint="#888888" android:padding="15dp"/>
                <TextView android:id="@+id/tvSeat6" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Empty" android:textColor="#888888" android:textSize="12sp" android:layout_marginTop="5dp"/>
            </LinearLayout>

            <LinearLayout android:id="@+id/seat7" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:gravity="center" android:orientation="vertical">
                <ImageView android:layout_width="60dp" android:layout_height="60dp" android:background="@drawable/bg_round_dark" android:src="@android:drawable/ic_secure" android:tint="#888888" android:padding="15dp"/>
                <TextView android:id="@+id/tvSeat7" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Empty" android:textColor="#888888" android:textSize="12sp" android:layout_marginTop="5dp"/>
            </LinearLayout>

            <LinearLayout android:id="@+id/seat8" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:gravity="center" android:orientation="vertical">
                <ImageView android:layout_width="60dp" android:layout_height="60dp" android:background="@drawable/bg_round_dark" android:src="@android:drawable/ic_secure" android:tint="#888888" android:padding="15dp"/>
                <TextView android:id="@+id/tvSeat8" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Empty" android:textColor="#888888" android:textSize="12sp" android:layout_marginTop="5dp"/>
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>

    <!-- 🎙️ MIC INDICATOR BAR (Video Jaisa) -->
    <LinearLayout
        android:id="@+id/micIndicator"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@id/seatsLayout"
        android:background="#2A2A35"
        android:padding="8dp"
        android:orientation="horizontal"
        android:gravity="center_vertical">
        
        <ImageView
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:src="@android:drawable/ic_btn_speak_now"
            android:tint="#FFC107"/>
            
        <TextView
            android:id="@+id/tvMicStatus"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginLeft="10dp"
            android:text="Your mic is off. Tap below to speak!"
            android:textColor="#FFFFFF"
            android:textSize="14sp"/>
    </LinearLayout>

    <!-- 💬 LIVE CHAT COMMENTS SECTION -->
    <ScrollView
        android:id="@+id/chatScroll"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/micIndicator"
        android:layout_above="@id/bottomControls"
        android:padding="10dp"
        android:scrollbars="none">

        <LinearLayout
            android:id="@+id/layoutMessages"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">
        </LinearLayout>
    </ScrollView>

    <!-- 🎛️ BOTTOM CONTROLS -->
    <RelativeLayout
        android:id="@+id/bottomControls"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:background="#1E1E28"
        android:padding="10dp">

        <ImageView
            android:id="@+id/btnMic"
            android:layout_width="45dp"
            android:layout_height="45dp"
            android:layout_alignParentLeft="true"
            android:layout_centerVertical="true"
            android:background="@drawable/bg_round_dark"
            android:src="@android:drawable/ic_btn_speak_now"
            android:tint="#888888"
            android:padding="10dp"/>

        <EditText
            android:id="@+id/etMessage"
            android:layout_width="match_parent"
            android:layout_height="45dp"
            android:layout_toRightOf="@id/btnMic"
            android:layout_toLeftOf="@id/rightIcons"
            android:layout_centerVertical="true"
            android:layout_marginHorizontal="10dp"
            android:background="@drawable/bg_round_dark"
            android:hint="Say something..."
            android:textColorHint="#888888"
            android:textColor="#FFFFFF"
            android:paddingHorizontal="15dp"
            android:textSize="14sp"/>

        <LinearLayout
            android:id="@+id/rightIcons"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentRight="true"
            android:layout_centerVertical="true"
            android:orientation="horizontal">
            
            <ImageView
                android:layout_width="35dp"
                android:layout_height="35dp"
                android:src="@android:drawable/ic_menu_share"
                android:tint="#FFC107"
                android:layout_marginRight="10dp"/>

            <ImageView
                android:id="@+id/btnSend"
                android:layout_width="45dp"
                android:layout_height="45dp"
                android:background="@drawable/bg_button"
                android:src="@android:drawable/ic_menu_send"
                android:tint="#FFFFFF"
                android:padding="10dp"/>
        </LinearLayout>
    </RelativeLayout>

</RelativeLayout>
