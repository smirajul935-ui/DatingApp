<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_main_gradient">

    <ImageView
        android:id="@+id/btnBack"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:layout_margin="20dp"
        android:src="@android:drawable/ic_menu_revert"
        android:tint="@color/text_white"/>

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_centerInParent="true"
        android:gravity="center"
        android:orientation="vertical">

        <!-- Glowing Icon -->
        <ImageView
            android:id="@+id/ivPulseGlow"
            android:layout_width="120dp"
            android:layout_height="120dp"
            android:background="@drawable/bg_speaker_glow"
            android:padding="24dp"
            android:src="@android:drawable/ic_menu_camera"
            android:tint="@color/neon_blue" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="Video Chat Coming Soon"
            android:textColor="@color/text_white"
            android:textSize="24sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="This premium feature will be\navailable in the next update!"
            android:textAlignment="center"
            android:textColor="@color/text_gray"
            android:textSize="16sp" />
    </LinearLayout>
</RelativeLayout>
